# Скопіюй у .env за потреби (усе має робочі дефолти).
PORT=3000
DB_PATH=data/links.db

# Дефолтний час життя лінка в днях, коли його не задано на створенні.
# Порожньо = рішення ще не ухвалене (docs/features/link-expiry/spec.md §8).
DEFAULT_TTL_DAYS=

# Ліміт створення лінків з однієї IP (docs/features/rate-limiting/).
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW_MS=60000
